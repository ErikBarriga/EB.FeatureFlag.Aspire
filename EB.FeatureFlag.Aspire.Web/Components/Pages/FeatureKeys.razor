@page "/sections/{SectionId:guid}/feature-keys"
@rendermode InteractiveServer
@using EB.FeatureFlag.Aspire.Web.Models
@inject FeatureFlagApiClient Api

<PageTitle>Feature Keys</PageTitle>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/products">Products</a></li>
        <li class="breadcrumb-item"><a href="/products/@_productId/sections">@(_productName ?? "...") - Sections</a></li>
        <li class="breadcrumb-item active">@(_sectionName ?? "...")</li>
    </ol>
</nav>

<h1>Feature Keys</h1>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

<div class="mb-3">
    <button class="btn btn-primary" @onclick="ShowCreate">+ New Feature Key</button>
</div>

@if (_featureKeys is null)
{
    <p><em>Loading...</em></p>
}
else if (_featureKeys.Count == 0)
{
    <p>No feature keys found.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Value</th>
                <th>Description</th>
                <th style="width:160px">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var fk in _featureKeys)
            {
                <tr>
                    <td>@fk.Name</td>
                    <td><span class="badge bg-info">@((FeatureKeyType)fk.Type)</span></td>
                    <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                        @FormatValue(fk)
                    </td>
                    <td>@fk.Description</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => ShowEdit(fk)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(fk.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editId.HasValue ? "Edit" : "Create") Feature Key</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input class="form-control" @bind="_formName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Type</label>
                            <select class="form-select" @bind="_formType" disabled="@_editId.HasValue">
                                @foreach (var t in Enum.GetValues<FeatureKeyType>())
                                {
                                    <option value="@((int)t)">@t</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input class="form-control" @bind="_formDescription" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tags (comma separated)</label>
                        <input class="form-control" @bind="_formTags" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Value</label>
                        @if ((FeatureKeyType)_formType == FeatureKeyType.Boolean)
                        {
                            <select class="form-select" @bind="_formValue">
                                <option value="true">true</option>
                                <option value="false">false</option>
                            </select>
                        }
                        else
                        {
                            <textarea class="form-control" rows="4" @bind="_formValue"
                                      placeholder="@GetValuePlaceholder()"></textarea>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Validation Regex (optional)</label>
                        <input class="form-control" @bind="_formValidationRegex" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @(_saving ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid SectionId { get; set; }

    private List<FeatureKeyModel>? _featureKeys;
    private string? _sectionName;
    private string? _productName;
    private Guid _productId;
    private string? _error;

    private bool _showForm;
    private bool _saving;
    private Guid? _editId;
    private string _formName = string.Empty;
    private string? _formDescription;
    private string? _formTags;
    private int _formType;
    private string _formValue = string.Empty;
    private string? _formValidationRegex;

    protected override async Task OnInitializedAsync()
    {
        var section = await Api.GetSectionAsync(SectionId);
        _sectionName = section?.Name;
        if (section is not null)
        {
            _productId = section.ProductId;
            var product = await Api.GetProductAsync(section.ProductId);
            _productName = product?.Name;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        try { _featureKeys = await Api.GetFeatureKeysAsync(SectionId); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private static string FormatValue(FeatureKeyModel fk)
    {
        if (fk.Value is null) return "(null)";
        return fk.Value.ToString() ?? "(null)";
    }

    private string GetValuePlaceholder() => (FeatureKeyType)_formType switch
    {
        FeatureKeyType.LargeString => "Enter text value",
        FeatureKeyType.StringCollection => "[\"value1\", \"value2\"]",
        FeatureKeyType.JsonCollection => "[{\"key\": \"value\"}]",
        _ => "Enter value"
    };

    private void ShowCreate()
    {
        _editId = null;
        _formName = string.Empty;
        _formDescription = null;
        _formTags = null;
        _formType = 0;
        _formValue = "false";
        _formValidationRegex = null;
        _showForm = true;
    }

    private void ShowEdit(FeatureKeyModel fk)
    {
        _editId = fk.Id;
        _formName = fk.Name;
        _formDescription = fk.Description;
        _formTags = fk.Tags is not null ? string.Join(", ", fk.Tags) : null;
        _formType = fk.Type;
        _formValue = fk.Value?.ToString() ?? string.Empty;
        _formValidationRegex = fk.ValidationRegex;
        _showForm = true;
    }

    private void CloseForm() => _showForm = false;

    private object? ParseValue()
    {
        return (FeatureKeyType)_formType switch
        {
            FeatureKeyType.Boolean => bool.TryParse(_formValue, out var b) ? b : false,
            _ => _formValue
        };
    }

    private async Task Save()
    {
        _saving = true;
        _error = null;
        try
        {
            var tags = string.IsNullOrWhiteSpace(_formTags)
                ? null
                : _formTags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

            var request = new
            {
                Name = _formName,
                Type = _formType,
                Value = ParseValue(),
                Description = _formDescription,
                Tags = tags,
                ValidationRegex = _formValidationRegex
            };

            if (_editId.HasValue)
                await Api.UpdateFeatureKeyAsync(_editId.Value, request);
            else
                await Api.CreateFeatureKeyAsync(SectionId, request);

            _showForm = false;
            await LoadData();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task Delete(Guid id)
    {
        _error = null;
        try
        {
            await Api.DeleteFeatureKeyAsync(id);
            await LoadData();
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
