@page "/products/{ProductId:guid}/environments"
@page "/environments"
@rendermode InteractiveServer
@inject FeatureFlagApiClient Api
@inject IJSRuntime JS

<PageTitle>Environments</PageTitle>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/products">Products</a></li>
        @if (_productName is not null)
        {
            <li class="breadcrumb-item active">@_productName - Environments</li>
        }
    </ol>
</nav>

<h1>Environments</h1>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

@if (ProductId == Guid.Empty)
{
    <div class="mb-3">
        <label class="form-label"><strong>Select a Product</strong></label>
        <select class="form-select" style="max-width:400px" @onchange="OnProductSelected">
            <option value="">-- Choose a product --</option>
            @if (_products is not null)
            {
                @foreach (var p in _products)
                {
                    <option value="@p.Id">@p.Name</option>
                }
            }
        </select>
    </div>
}

@if (_selectedProductId != Guid.Empty)
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="ShowCreate">+ New Environment</button>
    </div>

    @if (_environments is null)
    {
        <p><em>Loading...</em></p>
    }
    else if (_environments.Count == 0)
    {
        <p>No environments found.</p>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Tags</th>
                    <th style="width:300px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in _environments)
                {
                    <tr>
                        <td>@e.Name</td>
                        <td>@e.Description</td>
                        <td>@if (e.Tags is not null) { @foreach (var tag in e.Tags) { <span class="badge rounded-pill bg-secondary me-1">@tag</span> } }</td>
                        <td>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ShowEdit(e)">Edit</button>
                            <div class="btn-group" style="position:relative">
                                <button class="btn btn-sm btn-outline-warning dropdown-toggle" @onclick="() => ToggleRotateMenu(e.Id)">
                                    Rotate Keys
                                </button>
                                @if (_rotateMenuOpenFor == e.Id)
                                {
                                    <ul class="dropdown-menu show">
                                        <li><button class="dropdown-item" @onclick='() => ShowRotateConfirm(e.Id, "Primary")'>Rotate Primary Key</button></li>
                                        <li><button class="dropdown-item" @onclick='() => ShowRotateConfirm(e.Id, "Secondary")'>Rotate Secondary Key</button></li>
                                    </ul>
                                }
                            </div>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ShowDeleteConfirm(e.Id, e.Name)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@if (_confirmDeleteName is not null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDeleteConfirm"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger mb-3">
                        <strong>Warning:</strong> You are about to delete the environment <strong>@_confirmDeleteName</strong>.
                        Its access keys will be permanently invalidated.
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="confirmDeleteCheck" @bind="_confirmDeleteChecked" />
                        <label class="form-check-label" for="confirmDeleteCheck">
                            I understand and want to delete this environment
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDeleteConfirm">Cancel</button>
                    <button class="btn btn-danger" disabled="@(!_confirmDeleteChecked || _deleting)" @onclick="ConfirmDelete">
                        @(_deleting ? "Deleting..." : "Delete")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_confirmRotateKeyType is not null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Key Rotation</h5>
                    <button type="button" class="btn-close" @onclick="CancelRotateConfirm"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-danger mb-3">
                        <strong>Warning:</strong> Rotating the <strong>@_confirmRotateKeyType</strong> access key will immediately
                        invalidate the current key. Any application using it will lose access until updated with the new key.
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="confirmRotateCheck" @bind="_confirmRotateChecked" />
                        <label class="form-check-label" for="confirmRotateCheck">
                            I understand and want to rotate the <strong>@_confirmRotateKeyType</strong> key
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelRotateConfirm">Cancel</button>
                    <button class="btn btn-danger" disabled="@(!_confirmRotateChecked || _rotating)" @onclick="ConfirmRotateKey">
                        @(_rotating ? "Rotating..." : "Rotate Key")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_keysModalTitle is not null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@_keysModalTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseKeysModal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning mb-3">
                        <strong>Important:</strong> Copy and store these keys now. They will not be visible once you close this dialog.
                    </div>
                    @if (_showPrimaryKey is not null)
                    {
                        <div class="mb-3">
                            <label class="form-label"><strong>Primary Access Key</strong></label>
                            <div class="input-group">
                                <code class="form-control" style="background:#f8f9fa">@_showPrimaryKey</code>
                                <button class="btn btn-outline-secondary" @onclick="() => CopyToClipboard(_showPrimaryKey)" title="Copy">
                                    <i class="bi bi-clipboard"></i> Copy
                                </button>
                            </div>
                        </div>
                    }
                    @if (_showSecondaryKey is not null)
                    {
                        <div class="mb-3">
                            <label class="form-label"><strong>Secondary Access Key</strong></label>
                            <div class="input-group">
                                <code class="form-control" style="background:#f8f9fa">@_showSecondaryKey</code>
                                <button class="btn btn-outline-secondary" @onclick="() => CopyToClipboard(_showSecondaryKey)" title="Copy">
                                    <i class="bi bi-clipboard"></i> Copy
                                </button>
                            </div>
                        </div>
                    }
                    @if (_copySuccess)
                    {
                        <div class="alert alert-success py-1 mb-0">Copied to clipboard!</div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editId.HasValue ? "Edit" : "Create") Environment</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control" @bind="_formName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input class="form-control" @bind="_formDescription" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tags (comma separated)</label>
                        <input class="form-control" @bind="_formTags" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @(_saving ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ProductId { get; set; }

    private Guid _selectedProductId;
    private List<ProductModel>? _products;
    private List<EnvironmentModel>? _environments;
    private string? _productName;
    private string? _error;
    private string? _keysModalTitle;
    private string? _showPrimaryKey;
    private string? _showSecondaryKey;
    private bool _copySuccess;
    private Guid? _rotateMenuOpenFor;

    private Guid _confirmDeleteId;
    private string? _confirmDeleteName;
    private bool _confirmDeleteChecked;
    private bool _deleting;

    private Guid _confirmRotateId;
    private string? _confirmRotateKeyType;
    private bool _confirmRotateChecked;
    private bool _rotating;

    private bool _showForm;
    private bool _saving;
    private Guid? _editId;
    private string _formName = string.Empty;
    private string? _formDescription;
    private string? _formTags;

    protected override async Task OnInitializedAsync()
    {
        if (ProductId != Guid.Empty)
        {
            _selectedProductId = ProductId;
            var product = await Api.GetProductAsync(ProductId);
            _productName = product?.Name;
            await LoadData();
        }
        else
        {
            try { _products = await Api.GetProductsAsync(); }
            catch (Exception ex) { _error = ex.Message; }
        }
    }

    private async Task OnProductSelected(ChangeEventArgs e)
    {
        _environments = null;
        _productName = null;

        if (Guid.TryParse(e.Value?.ToString(), out var productId) && productId != Guid.Empty)
        {
            _selectedProductId = productId;
            var product = _products?.FirstOrDefault(p => p.Id == productId);
            _productName = product?.Name;
            await LoadData();
        }
        else
        {
            _selectedProductId = Guid.Empty;
        }
    }

    private async Task LoadData()
    {
        try { _environments = await Api.GetEnvironmentsAsync(_selectedProductId); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private void ShowCreate()
    {
        _editId = null;
        _formName = string.Empty;
        _formDescription = null;
        _formTags = null;
        _showForm = true;
    }

    private void ShowEdit(EnvironmentModel e)
    {
        _editId = e.Id;
        _formName = e.Name;
        _formDescription = e.Description;
        _formTags = e.Tags is not null ? string.Join(", ", e.Tags) : null;
        _showForm = true;
    }

    private void CloseForm() => _showForm = false;

    private async Task Save()
    {
        _saving = true;
        _error = null;
        try
        {
            var tags = string.IsNullOrWhiteSpace(_formTags)
                ? null
                : _formTags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

            var request = new { Name = _formName, Description = _formDescription, Tags = tags };

            if (_editId.HasValue)
            {
                await Api.UpdateEnvironmentAsync(_editId.Value, request);
            }
            else
            {
                var created = await Api.CreateEnvironmentAsync(_selectedProductId, request);
                if (created is not null)
                {
                    _keysModalTitle = $"Access Keys - {created.Name}";
                    _showPrimaryKey = created.PrimaryAccessKey;
                    _showSecondaryKey = created.SecondaryAccessKey;
                }
            }

            _showForm = false;
            await LoadData();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private void ShowDeleteConfirm(Guid id, string name)
    {
        _confirmDeleteId = id;
        _confirmDeleteName = name;
        _confirmDeleteChecked = false;
    }

    private void CancelDeleteConfirm()
    {
        _confirmDeleteName = null;
        _confirmDeleteChecked = false;
    }

    private async Task ConfirmDelete()
    {
        _deleting = true;
        _error = null;
        try
        {
            await Api.DeleteEnvironmentAsync(_confirmDeleteId);
            _confirmDeleteName = null;
            _confirmDeleteChecked = false;
            await LoadData();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _deleting = false; }
    }

    private void ToggleRotateMenu(Guid id)
        => _rotateMenuOpenFor = _rotateMenuOpenFor == id ? null : id;

    private void ShowRotateConfirm(Guid id, string keyType)
    {
        _rotateMenuOpenFor = null;
        _confirmRotateId = id;
        _confirmRotateKeyType = keyType;
        _confirmRotateChecked = false;
    }

    private void CancelRotateConfirm()
    {
        _confirmRotateKeyType = null;
        _confirmRotateChecked = false;
    }

    private async Task ConfirmRotateKey()
    {
        _rotating = true;
        _error = null;
        _copySuccess = false;
        try
        {
            var result = await Api.RotateEnvironmentKeysAsync(_confirmRotateId, _confirmRotateKeyType!);
            _confirmRotateKeyType = null;
            _confirmRotateChecked = false;
            if (result is not null)
            {
                _keysModalTitle = $"Rotated {result.KeyType} Access Key";
                _showPrimaryKey = result.KeyType == "Primary" ? result.NewKey : null;
                _showSecondaryKey = result.KeyType == "Secondary" ? result.NewKey : null;
            }
            await LoadData();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _rotating = false; }
    }

    private void CloseKeysModal()
    {
        _keysModalTitle = null;
        _showPrimaryKey = null;
        _showSecondaryKey = null;
        _copySuccess = false;
    }

    private async Task CopyToClipboard(string text)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        _copySuccess = true;
        StateHasChanged();
    }
}
