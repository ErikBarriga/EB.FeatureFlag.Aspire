@page "/sdk-explorer"
@rendermode InteractiveServer
@using EB.FeatureFlag.Aspire.Web.Models
@inject FeatureFlagApiClient Api

<PageTitle>SDK Explorer</PageTitle>

<h1>SDK Explorer</h1>
<p class="text-muted">Test the SDK endpoints by querying a feature flag using an environment access key.</p>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label"><strong>Environment Access Key</strong></label>
                <input class="form-control" @bind="_accessKey" placeholder="Paste a Primary or Secondary access key" />
            </div>
            <div class="col-md-6">
                <label class="form-label"><strong>Feature Flag Key</strong></label>
                <input class="form-control" @bind="_flagKey" placeholder="e.g. LoggerLevel_1-DEMO" />
            </div>
        </div>
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <button class="nav-link @(_mode == "value" ? "active" : "")" @onclick='() => _mode = "value"'>Value Only</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(_mode == "full" ? "active" : "")" @onclick='() => _mode = "full"'>Full Details</button>
            </li>
        </ul>
        <button class="btn btn-primary" @onclick="Fetch" disabled="@(_loading || string.IsNullOrWhiteSpace(_accessKey) || string.IsNullOrWhiteSpace(_flagKey))">
            @(_loading ? "Loading..." : "Fetch Feature Flag")
        </button>
    </div>
</div>

@if (_fullResult is not null)
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <span class="badge bg-primary me-1">@_fullResult.Product</span>
                <span class="badge bg-success me-1">@_fullResult.Environment</span>
                <span class="badge bg-secondary">@_fullResult.Section</span>
            </div>
            <span class="badge bg-info">@((FeatureKeyType)_fullResult.Type)</span>
        </div>
        <div class="card-body">
            <h5 class="card-title"><code>@_fullResult.Key</code></h5>
            <div class="mt-3">
                <label class="form-label text-muted"><strong>Value</strong></label>
                @RenderValue(_fullResult.Type, _fullResult.Value)
            </div>
        </div>
    </div>
}

@if (_valueResult is not null)
{
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="text-muted">Value Only Response</span>
            <span class="badge bg-info">@((FeatureKeyType)_valueResult.Type)</span>
        </div>
        <div class="card-body">
            @RenderValue(_valueResult.Type, _valueResult.Value)
        </div>
    </div>
}

@code {
    private string _accessKey = string.Empty;
    private string _flagKey = string.Empty;
    private string _mode = "value";
    private string? _error;
    private bool _loading;
    private SdkSingleFeatureFlagResponseModel? _fullResult;
    private SdkFeatureFlagValueResponseModel? _valueResult;

    private async Task Fetch()
    {
        _loading = true;
        _error = null;
        _fullResult = null;
        _valueResult = null;
        try
        {
            if (_mode == "full")
                _fullResult = await Api.GetSdkFeatureFlagAsync(_accessKey.Trim(), _flagKey.Trim());
            else
                _valueResult = await Api.GetSdkFeatureFlagValueAsync(_accessKey.Trim(), _flagKey.Trim());
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _error = $"Feature flag '{_flagKey.Trim()}' was not found. Verify the flag key and access key.";
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.BadRequest)
        {
            _error = "The environment access key header is required.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally { _loading = false; }
    }

    private RenderFragment RenderValue(int type, object? value) => builder =>
    {
        if (value is null)
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "text-muted fst-italic");
            builder.AddContent(2, "(not set)");
            builder.CloseElement();
        }
        else if ((FeatureKeyType)type == FeatureKeyType.Boolean)
        {
            var boolVal = value.ToString()?.Equals("true", StringComparison.OrdinalIgnoreCase) == true
                       || value.ToString()?.Equals("True", StringComparison.OrdinalIgnoreCase) == true;
            builder.OpenElement(0, "div");
            builder.OpenElement(1, "span");
            builder.AddAttribute(2, "class", $"badge fs-6 {(boolVal ? "bg-success" : "bg-danger")}");
            builder.AddContent(3, value);
            builder.CloseElement();
            builder.CloseElement();
        }
        else
        {
            builder.OpenElement(0, "pre");
            builder.AddAttribute(1, "class", "bg-body-secondary p-3 rounded border");
            builder.AddAttribute(2, "style", "white-space:pre-wrap;word-break:break-word");
            builder.AddContent(3, value);
            builder.CloseElement();
        }
    };
}
