@page "/feature-flags"
@page "/products/{ProductId:guid}/feature-flags"
@page "/sections/{SectionId:guid}/feature-flags"
@rendermode InteractiveServer
@using EB.FeatureFlag.Aspire.Web.Models
@inject FeatureFlagApiClient Api

<PageTitle>Feature Flags</PageTitle>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/products">Products</a></li>
        @if (_productName is not null)
        {
            <li class="breadcrumb-item active">@_productName - Feature Flags</li>
        }
    </ol>
</nav>

<h1>Feature Flags</h1>

@if (_error is not null)
{
    <div class="alert alert-danger alert-dismissible">
        @_error
        <button type="button" class="btn-close" @onclick="() => _error = null"></button>
    </div>
}

@* Product selector when no ProductId in route *@
@if (ProductId == Guid.Empty && SectionId == Guid.Empty)
{
    <div class="mb-3">
        <label class="form-label"><strong>Select a Product</strong></label>
        <select class="form-select" style="max-width:400px" @onchange="OnProductSelected">
            <option value="">-- Choose a product --</option>
            @if (_products is not null)
            {
                @foreach (var p in _products)
                {
                    <option value="@p.Id">@p.Name</option>
                }
            }
        </select>
    </div>
}

@if (_selectedProductId != Guid.Empty)
{
    @* Optional section filter *@
    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">Filter by Section</label>
            <select class="form-select" @onchange="OnSectionFilterChanged">
                <option value="">All Sections</option>
                @if (_sections is not null)
                {
                    @foreach (var s in _sections)
                    {
                        <option value="@s.Id" selected="@(s.Id == _filterSectionId)">@s.Name</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <button class="btn btn-primary" @onclick="ShowCreate">+ New Feature Flag</button>
        </div>
    </div>

    @if (_featureFlags is null)
    {
        <p><em>Loading...</em></p>
    }
    else if (_featureFlags.Count == 0)
    {
        <p>No feature flags found.</p>
    }
    else
    {
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Section</th>
                    <th>Type</th>
                    <th>Description</th>
                    <th>Tags</th>
                    <th style="width:200px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ff in _filteredFlags)
                {
                    <tr>
                        <td>@ff.Name</td>
                        <td>@GetSectionName(ff.SectionId)</td>
                        <td><span class="badge bg-info">@((FeatureKeyType)ff.Type)</span></td>
                        <td>@ff.Description</td>
                        <td>@(ff.Tags is not null ? string.Join(", ", ff.Tags) : "")</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowDetails(ff)">Details</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => ShowEdit(ff)">Edit</button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(ff.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@* Create / Edit Feature Flag modal *@
@if (_showForm)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editId.HasValue ? "Edit" : "Create") Feature Flag</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Name</label>
                            <input class="form-control" @bind="_formName" />
                        </div>
                        <div class="col-md-6">
                            @if (!_editId.HasValue)
                            {
                                <label class="form-label">Section</label>
                                <select class="form-select" @bind="_formSectionId">
                                    <option value="">-- Select section --</option>
                                    @if (_sections is not null)
                                    {
                                        @foreach (var s in _sections)
                                        {
                                            <option value="@s.Id">@s.Name</option>
                                        }
                                    }
                                </select>
                            }
                            else
                            {
                                <label class="form-label">Section</label>
                                <input class="form-control" value="@GetSectionName(_formSectionId)" disabled />
                            }
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Type</label>
                            <select class="form-select" @bind="_formType" disabled="@_editId.HasValue">
                                @foreach (var t in Enum.GetValues<FeatureKeyType>())
                                {
                                    <option value="@((int)t)">@t</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Validation Regex (optional)</label>
                            <input class="form-control" @bind="_formValidationRegex" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input class="form-control" @bind="_formDescription" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tags (comma separated)</label>
                        <input class="form-control" @bind="_formTags" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveFlag" disabled="@_saving">
                        @(_saving ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Details modal: per-environment values *@
@if (_showDetails && _detailFlag is not null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @_detailFlag.Name
                        <span class="badge bg-info ms-2">@((FeatureKeyType)_detailFlag.Type)</span>
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseDetails"></button>
                </div>
                <div class="modal-body">
                    @if (_details is null)
                    {
                        <p><em>Loading environment details...</em></p>
                    }
                    else if (_details.Count == 0)
                    {
                        <p>No environment details found. Create environments in the product first.</p>
                    }
                    else
                    {
                        <table class="table table-bordered">
                            <thead>
                                <tr>
                                    <th style="width:200px">Environment</th>
                                    <th>Value</th>
                                    <th style="width:120px">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detail in _details)
                                {
                                    var envName = GetEnvironmentName(detail.EnvironmentId);
                                    <tr>
                                        <td><strong>@envName</strong></td>
                                        <td>
                                            @if (_editDetailId == detail.Id)
                                            {
                                                @if ((FeatureKeyType)_detailFlag.Type == FeatureKeyType.Boolean)
                                                {
                                                    <select class="form-select" @bind="_detailFormValue">
                                                        <option value="true">true</option>
                                                        <option value="false">false</option>
                                                    </select>
                                                }
                                                else
                                                {
                                                    <textarea class="form-control" rows="3" @bind="_detailFormValue"
                                                              placeholder="@GetValuePlaceholder()"></textarea>
                                                }
                                            }
                                            else
                                            {
                                                <span style="max-width:600px;display:inline-block;word-break:break-word">
                                                    @(TruncateValue(detail.Value?.ToString(), 200))
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            @if (_editDetailId == detail.Id)
                                            {
                                                <button class="btn btn-sm btn-primary" @onclick="SaveDetail" disabled="@_savingDetail">
                                                    @(_savingDetail ? "..." : "Save")
                                                </button>
                                                <button class="btn btn-sm btn-secondary" @onclick="CancelDetailEdit">Cancel</button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => StartDetailEdit(detail)">Edit</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseDetails">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid ProductId { get; set; }
    [Parameter] public Guid SectionId { get; set; }

    // Data
    private List<ProductModel>? _products;
    private List<SectionModel>? _sections;
    private List<EnvironmentModel>? _environments;
    private List<FeatureFlagModel>? _featureFlags;
    private string? _productName;
    private Guid _selectedProductId;
    private Guid _filterSectionId;
    private string? _error;

    // Computed filtered list
    private List<FeatureFlagModel> _filteredFlags =>
        _featureFlags is null ? []
        : _filterSectionId == Guid.Empty ? _featureFlags
        : _featureFlags.Where(f => f.SectionId == _filterSectionId).ToList();

    // Create/Edit form
    private bool _showForm;
    private bool _saving;
    private Guid? _editId;
    private string _formName = string.Empty;
    private Guid _formSectionId;
    private int _formType;
    private string? _formDescription;
    private string? _formTags;
    private string? _formValidationRegex;

    // Details modal
    private bool _showDetails;
    private FeatureFlagModel? _detailFlag;
    private List<FeatureFlagDetailModel>? _details;
    private Guid? _editDetailId;
    private string _detailFormValue = string.Empty;
    private bool _savingDetail;

    protected override async Task OnInitializedAsync()
    {
        if (SectionId != Guid.Empty)
        {
            // Resolve product from section
            var section = await Api.GetSectionAsync(SectionId);
            if (section is not null)
            {
                _selectedProductId = section.ProductId;
                _filterSectionId = SectionId;
                var product = await Api.GetProductAsync(section.ProductId);
                _productName = product?.Name;
                await LoadProductData();
            }
        }
        else if (ProductId != Guid.Empty)
        {
            _selectedProductId = ProductId;
            var product = await Api.GetProductAsync(ProductId);
            _productName = product?.Name;
            await LoadProductData();
        }
        else
        {
            try { _products = await Api.GetProductsAsync(); }
            catch (Exception ex) { _error = ex.Message; }
        }
    }

    private async Task OnProductSelected(ChangeEventArgs e)
    {
        _featureFlags = null;
        _sections = null;
        _environments = null;
        _productName = null;
        _filterSectionId = Guid.Empty;

        if (Guid.TryParse(e.Value?.ToString(), out var productId) && productId != Guid.Empty)
        {
            _selectedProductId = productId;
            var product = _products?.FirstOrDefault(p => p.Id == productId);
            _productName = product?.Name;
            await LoadProductData();
        }
        else
        {
            _selectedProductId = Guid.Empty;
        }
    }

    private async Task LoadProductData()
    {
        try
        {
            _sections = await Api.GetSectionsByProductAsync(_selectedProductId);
            _environments = await Api.GetEnvironmentsAsync(_selectedProductId);
            _featureFlags = await Api.GetFeatureFlagsByProductAsync(_selectedProductId);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task OnSectionFilterChanged(ChangeEventArgs e)
    {
        _filterSectionId = Guid.TryParse(e.Value?.ToString(), out var sid) ? sid : Guid.Empty;
        await Task.CompletedTask;
    }

    private string GetSectionName(Guid sectionId)
        => _sections?.FirstOrDefault(s => s.Id == sectionId)?.Name ?? "...";

    private string GetEnvironmentName(Guid environmentId)
        => _environments?.FirstOrDefault(e => e.Id == environmentId)?.Name ?? "...";

    private string TruncateValue(string? value, int maxLength)
    {
        if (string.IsNullOrEmpty(value)) return "(not set)";
        return value.Length <= maxLength ? value : value[..maxLength] + "...";
    }

    private string GetValuePlaceholder() => (FeatureKeyType)(_detailFlag?.Type ?? 0) switch
    {
        FeatureKeyType.LargeString => "Enter text value",
        FeatureKeyType.StringCollection => "[\"value1\", \"value2\"]",
        FeatureKeyType.JsonCollection => "[{\"key\": \"value\"}]",
        _ => "Enter value"
    };

    // --- Create/Edit Feature Flag ---

    private void ShowCreate()
    {
        _editId = null;
        _formName = string.Empty;
        _formSectionId = _filterSectionId;
        _formType = 0;
        _formDescription = null;
        _formTags = null;
        _formValidationRegex = null;
        _showForm = true;
    }

    private void ShowEdit(FeatureFlagModel ff)
    {
        _editId = ff.Id;
        _formName = ff.Name;
        _formSectionId = ff.SectionId;
        _formType = ff.Type;
        _formDescription = ff.Description;
        _formTags = ff.Tags is not null ? string.Join(", ", ff.Tags) : null;
        _formValidationRegex = ff.ValidationRegex;
        _showForm = true;
    }

    private void CloseForm() => _showForm = false;

    private async Task SaveFlag()
    {
        _saving = true;
        _error = null;
        try
        {
            var tags = string.IsNullOrWhiteSpace(_formTags)
                ? null
                : _formTags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

            if (_editId.HasValue)
            {
                var request = new
                {
                    Name = _formName,
                    Description = _formDescription,
                    Tags = tags,
                    ValidationRegex = _formValidationRegex
                };
                await Api.UpdateFeatureFlagAsync(_editId.Value, request);
            }
            else
            {
                var request = new
                {
                    Name = _formName,
                    Type = _formType,
                    Description = _formDescription,
                    Tags = tags,
                    ValidationRegex = _formValidationRegex
                };
                await Api.CreateFeatureFlagAsync(_formSectionId, request);
            }

            _showForm = false;
            _featureFlags = await Api.GetFeatureFlagsByProductAsync(_selectedProductId);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task Delete(Guid id)
    {
        _error = null;
        try
        {
            await Api.DeleteFeatureFlagAsync(id);
            _featureFlags = await Api.GetFeatureFlagsByProductAsync(_selectedProductId);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    // --- Details (per-environment values) ---

    private async Task ShowDetails(FeatureFlagModel ff)
    {
        _detailFlag = ff;
        _details = null;
        _editDetailId = null;
        _showDetails = true;
        try
        {
            _details = await Api.GetFeatureFlagDetailsAsync(ff.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private void CloseDetails()
    {
        _showDetails = false;
        _detailFlag = null;
        _details = null;
        _editDetailId = null;
    }

    private void StartDetailEdit(FeatureFlagDetailModel detail)
    {
        _editDetailId = detail.Id;
        _detailFormValue = detail.Value?.ToString() ?? string.Empty;
    }

    private void CancelDetailEdit() => _editDetailId = null;

    private object? ParseDetailValue()
    {
        if (_detailFlag is null) return _detailFormValue;
        return (FeatureKeyType)_detailFlag.Type switch
        {
            FeatureKeyType.Boolean => bool.TryParse(_detailFormValue, out var b) ? b : false,
            _ => _detailFormValue
        };
    }

    private async Task SaveDetail()
    {
        if (_editDetailId is null) return;
        _savingDetail = true;
        _error = null;
        try
        {
            var request = new { Value = ParseDetailValue() };
            await Api.UpdateFeatureFlagDetailAsync(_editDetailId.Value, request);
            _details = await Api.GetFeatureFlagDetailsAsync(_detailFlag!.Id);
            _editDetailId = null;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _savingDetail = false; }
    }
}
